APP_NAME="UTransit API"
APP_ENV="development"
APP_PORT=8000
CORS_ORIGINS="http://localhost:5173,http://localhost:3000,http://localhost:8080"

# JWT auth (use a strong secret in production)
JWT_SECRET="change-me-in-production"

# For AWS RDS use the endpoint from the console and keep sslmode=require.
DATABASE_URL="postgresql://utransit_admin:CHANGE_ME@your-rds-endpoint.rds.amazonaws.com:5432/utransit?sslmode=require"

# Dev safety net: if primary DB fails, fallback to local SQLite.
DB_FALLBACK_ENABLED=true
DB_FALLBACK_DATABASE_URL="sqlite:///./utransit.db"
